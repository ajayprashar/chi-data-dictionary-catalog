            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "1. Standards & Contexts \u2014 choose Patient.race in the concept slicer (pilots filter = yes).",
                    "textStyle": {
                      "fontSize": "12pt",
                      "color": "#000000"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "   Read FHIR path, governed codes, crosswalk, then ADT (field_id + CE encoding) and C-CDA XPath.",
                    "textStyle": {
                      "fontSize": "12pt",
                      "color": "#000000"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "2. Repeat with Patient.language \u2014 ADT field_id should show PID-15 (hl7_ce_encoding may be blank).",
                    "textStyle": {
                      "fontSize": "12pt",
                      "color": "#000000"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "3. Concept Profile \u2014 governance cards, survivorship, and source availability for the same concept.",
                    "textStyle": {
                      "fontSize": "12pt",
                      "color": "#000000"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "4. Field guide \u2014 filter by page or visual; steward_action shows which Excel sheet to edit.",
                    "textStyle": {
                      "fontSize": "12pt",
                      "color": "#000000"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "5. Governance Overview \u2014 portfolio KPIs and full concept list (most rows are not yet curated).",
                    "textStyle": {
                      "fontSize": "12pt",
                      "color": "#000000"
                    }
                  }
                ]
              }
            ]
          }
